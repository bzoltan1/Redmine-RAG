# Evaluation questions for the Redmine RAG system.
# Format: one JSON object per line.
# Fields:
#   question         - natural language query
#   expected_ids     - list of Redmine issue IDs that MUST appear in top-K results
#   tags             - optional list of labels for grouping results (e.g. project, type)
#
# Lines starting with '#' are ignored.

{"question": "What kernel-related issues have been reported as high priority?", "expected_ids": [], "tags": ["qe-kernel", "priority"]}
