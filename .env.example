# Copy this file to .env and fill in your values.
# Never commit .env to version control.

# --- Redmine connection ---
REDMINE_BASE_URL=https://progress.opensuse.org
REDMINE_API_KEY=your_api_key_here

# Comma-separated list of Redmine project identifiers to download
PROJECT_IDS=virtualization,performance,qesecurity,qe-kernel,qam,qe-yast,openqatests,openqa-infrastructure,containers

# --- Download behaviour ---
RATE_LIMIT_SECONDS=2.0
MAX_RETRIES=3
SAVE_INTERVAL=50

# --- Data paths (relative to repo root, or absolute) ---
DATA_DIR=./data
RAW_DIR=./data/raw
MASTER_FILE=./data/redmine_master.json
ANONYMIZED_FILE=./data/redmine_anonymized.json
USER_MAPPING_FILE=./data/user_mapping.json

# --- ChromaDB ---
CHROMA_DIR=./data/chroma_db
COLLECTION_NAME=redmine_issues

# --- Ollama ---
OLLAMA_HOST=http://localhost:11434
EMBED_MODEL=nomic-embed-text
CHAT_MODEL=llama3.2

# --- Ingest ---
BATCH_SIZE=50
MAX_TEXT_LEN=8192

# --- Query ---
TOP_K=5

# --- Development mode ---
# Used when any pipeline script is run with --dev
# Isolates dev data completely from production data.
DEV_PROJECT_ID=qesecurity
DEV_DATA_DIR=./data/dev
DEV_COLLECTION_NAME=redmine_issues_dev
